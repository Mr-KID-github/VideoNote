# ============ 服务配置 ============
HOST=0.0.0.0
PORT=8900

# ============ LLM 配置 ============
# 支持所有 OpenAI 兼容 API（OpenAI / DeepSeek / 通义千问 / Ollama 等）
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai-compatible

# ============ Supabase Backend Integration ============
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ============ Model Profile Security ============
MODEL_PROFILE_ENCRYPTION_KEY=replace-with-a-long-random-secret
AZURE_OPENAI_API_VERSION=2024-10-21

# ============ 转写配置 ============
# 转写器类型: groq (云端) / whisper (本地 openai-whisper) / faster-whisper (本地推荐) / sensevoice / sensevoice-local
TRANSCRIBER_TYPE=groq

# Groq Whisper API (https://console.groq.com/keys 获取免费 Key)
GROQ_API_KEY=gsk_your-groq-api-key

# 本地 Whisper (TRANSCRIBER_TYPE=whisper 时使用)
# WHISPER_MODEL_SIZE=base
# WHISPER_DEVICE=cpu

# Faster-Whisper (TRANSCRIBER_TYPE=faster-whisper 时使用，推荐)
# WHISPER_MODEL_SIZE=base         # tiny/base/small/medium/large-v3
# WHISPER_DEVICE=cpu              # cpu 或 cuda
# FASTER_WHISPER_COMPUTE_TYPE=int8  # int8/float16/float32

# ============ 存储路径 ============
DATA_DIR=data
OUTPUT_DIR=output

# 闀块煶棰戝垎娈佃浆鍐?锛堥粯璁ゅ紑鍚級
# 浼氬湪杩囬暱闊抽涓婅嚜鍔ㄥ仛甯﹀墠鍚庢枃鐨勫垎娈碉紝閬垮厤浜戠 ASR 413
# TRANSCRIPTION_CHUNKING_ENABLED=true
# TRANSCRIPTION_CHUNK_MAX_DURATION_SECONDS=1200
# TRANSCRIPTION_CHUNK_OVERLAP_SECONDS=120
# TRANSCRIPTION_CHUNK_TARGET_FILE_SIZE_MB=20
# TRANSCRIPTION_CHUNK_MIN_CORE_SECONDS=300
# TRANSCRIPTION_CHUNK_BITRATE_KBPS=64
