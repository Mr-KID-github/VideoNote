# ============ Service ============
HOST=0.0.0.0
PORT=8900
CORS_ALLOW_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
BACKEND_PORT=8900
FRONTEND_PORT=3100
POSTGRES_PORT=54322

# ============ App Auth ============
APP_JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_SECONDS=604800
AUTH_COOKIE_NAME=vinote_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# ============ Database ============
POSTGRES_DB=vinote
POSTGRES_USER=vinote
POSTGRES_PASSWORD=change-me-to-a-long-random-db-password
DATABASE_URL=postgresql+psycopg://vinote:change-me-to-a-long-random-db-password@127.0.0.1:54322/vinote

# ============ LLM ============
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai-compatible

# ============ Model Profile Security ============
MODEL_PROFILE_ENCRYPTION_KEY=replace-with-a-long-random-secret
AZURE_OPENAI_API_VERSION=2024-10-21

# ============ Transcriber ============
TRANSCRIBER_TYPE=groq
GROQ_API_KEY=gsk_your-groq-api-key

# ============ Storage ============
DATA_DIR=data
OUTPUT_DIR=output

# ============ Frontend Runtime ============
VITE_API_BASE_URL=
