# ============ 服务配置 ============
HOST=0.0.0.0
PORT=8900
CORS_ALLOW_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
BACKEND_PORT=8900
FRONTEND_PORT=3100
SUPABASE_PORT=54321
SUPABASE_DB_PORT=54322

# ============ Built-in Supabase Stack ============
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q
SITE_URL=http://localhost:3100
ADDITIONAL_REDIRECT_URLS=http://localhost:3100,http://127.0.0.1:3100
API_EXTERNAL_URL=http://localhost:3100/supabase/auth/v1
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=VINote
MAILER_URLPATHS_INVITE=/login
MAILER_URLPATHS_CONFIRMATION=/login
MAILER_URLPATHS_RECOVERY=/login
MAILER_URLPATHS_EMAIL_CHANGE=/settings
PGRST_DB_SCHEMAS=public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

# ============ LLM 配置 ============
# 支持所有 OpenAI 兼容 API（OpenAI / DeepSeek / 通义千问 / Ollama 等）
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai-compatible

# ============ Supabase Backend Integration ============
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# ============ Model Profile Security ============
MODEL_PROFILE_ENCRYPTION_KEY=replace-with-a-long-random-secret
AZURE_OPENAI_API_VERSION=2024-10-21

# ============ 转写配置 ============
# 转写器类型: groq (云端) / whisper (本地 openai-whisper) / faster-whisper (本地推荐) / sensevoice / sensevoice-local
TRANSCRIBER_TYPE=groq

# Groq Whisper API (https://console.groq.com/keys 获取免费 Key)
GROQ_API_KEY=gsk_your-groq-api-key

# 本地 Whisper (TRANSCRIBER_TYPE=whisper 时使用)
# WHISPER_MODEL_SIZE=base
# WHISPER_DEVICE=cpu

# Faster-Whisper (TRANSCRIBER_TYPE=faster-whisper 时使用，推荐)
# WHISPER_MODEL_SIZE=base         # tiny/base/small/medium/large-v3
# WHISPER_DEVICE=cpu              # cpu 或 cuda
# FASTER_WHISPER_COMPUTE_TYPE=int8  # int8/float16/float32

# ============ 存储路径 ============
DATA_DIR=data
OUTPUT_DIR=output

# ============ Frontend Runtime Config ============
# Docker / Nginx 前端容器会在启动时读取这些值写入 runtime-config.js
VITE_API_BASE_URL=
VITE_SUPABASE_URL=/supabase
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

