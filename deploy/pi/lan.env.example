# Raspberry Pi LAN test environment overrides
# Copy these values into the repository root .env file, then replace them with your Raspberry Pi LAN address.

FRONTEND_PORT=3100
BACKEND_PORT=8900
POSTGRES_PORT=54322

# Replace the address below with your Raspberry Pi LAN IP or hostname.
CORS_ALLOW_ORIGINS=http://192.168.1.50:3100,http://vinote.local:3100
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
