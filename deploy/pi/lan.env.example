# Raspberry Pi LAN test environment overrides
# Copy these values into the repository root .env file, then replace them with your Raspberry Pi LAN address.

FRONTEND_PORT=3100
BACKEND_PORT=8900
SUPABASE_PORT=54321
SUPABASE_DB_PORT=54322

# Replace the two addresses below with your Raspberry Pi LAN IP or hostname.
SITE_URL=http://192.168.1.50:3100
API_EXTERNAL_URL=http://192.168.1.50:3100/supabase/auth/v1
ADDITIONAL_REDIRECT_URLS=http://192.168.1.50:3100,http://vinote.local:3100
CORS_ALLOW_ORIGINS=http://192.168.1.50:3100,http://vinote.local:3100
